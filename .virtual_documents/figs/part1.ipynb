


import numpy as np
import pandas as pd
import matplotlib as mpl
import matplotlib.pyplot as plt
import seaborn as sns
from tqdm import tqdm
import warnings; warnings.filterwarnings(action='once')


data_info = pd.read_csv("../dataset/dataset_labels.csv")
data_info

















data_widom = pd.read_csv("../benchmark/gcmc/data/h2o_widom.csv")
data_widom


data_r = []
data_f = []

for i, name in tqdm(enumerate(data_info["refcode"])):
    if data_info["r2f"][i] == 1:
        r = data_widom[data_widom["name"] == name + "_R_pacman"]["KH"]
        f = data_widom[data_widom["name"] == name + "_F_pacman"]["KH"]
        if len(f) == 0:
            f = data_widom[data_widom["name"] == name + "_IF_pacman"]["KH"]
            
        if len(r) == 0:
            print(f"Missing R: {name}")
            continue

        if len(f) == 0:
            print(f"Missing F: {name}")
            continue

        r_val = round(float(r.iloc[0]), 30)
        f_val = round(float(f.iloc[0]), 30)

        data_r.append(r_val)
        data_f.append(f_val)


data_rr = []
data_a = []

for i, name in tqdm(enumerate(data_info["refcode"])):
    if data_info["f2a"][i] == 1:
        r = data_widom[data_widom["name"] == name + "_R_pacman"]["KH"]
        a = data_widom[data_widom["name"] == name + "_A_pacman"]["KH"]
        if len(a) == 0:
            a = data_widom[data_widom["name"] == name + "_IA_pacman"]["KH"]
            
        if len(r) == 0:
            print(f"Missing R: {name}")
            continue

        if len(a) == 0:
            print(f"Missing A: {name}")
            continue

        r_val = round(float(r.iloc[0]), 30)
        a_val = round(float(a.iloc[0]), 30)

        data_rr.append(r_val)
        data_a.append(a_val)


fig = plt.figure(figsize=(14, 10), dpi=600)
grid = plt.GridSpec(4, 4, hspace=0.5, wspace=0.2)

ax_main = fig.add_subplot(grid[:-1, :-1])
ax_right = fig.add_subplot(grid[:-1, -1], xticklabels=[], yticklabels=[])
ax_bottom = fig.add_subplot(grid[-1, 0:-1], xticklabels=[], yticklabels=[])

ax_main.scatter(
    data_r,
    data_f,
    s=20,
    alpha=.9,
    edgecolors='gray',
    linewidths=.5
)

# ax_main.scatter(
#     data_rr,
#     data_a,
#     s=20,
#     alpha=.9,
#     c="r",
#     edgecolors='gray',
#     linewidths=.5
# )

ax_main.set_xscale("log")
ax_main.set_yscale("log")
ax_main.set_xlim(1e-30,1e-4)
ax_main.set_ylim(1e-30,1e-4)

sns.boxplot(data_f, ax=ax_right, orient="v")
sns.boxplot(data_r, ax=ax_bottom, orient="h")

ax_bottom.set_xscale("log")
ax_bottom.set_xlim(1e-30,1e-4)

ax_right.set_yscale("log")
ax_right.set_ylim(1e-30,1e-4)

ax_main.set_xlabel('raw', fontsize=16)
ax_main.set_ylabel('F', fontsize=16)

for item in (
    ax_main.get_xticklabels() +
    ax_main.get_yticklabels()
):
    item.set_fontsize(14)

plt.show()



